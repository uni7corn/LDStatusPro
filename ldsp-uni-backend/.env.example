# Server
HOST=0.0.0.0
PORT=8790
ENVIRONMENT=development
DEBUG=true

# Databases
LDSP_DATABASE_PATH=./data/ldsp_data.db
STORE_DATABASE_PATH=./data/ld_store.db
VECTOR_STORE_PATH=./data/vector_store

# JWT Auth
JWT_SECRET_KEY=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# OAuth
# 回调基础地址，例如: https://api1.ldspro.qzz.io
API_BASE_URL=https://api1.ldspro.qzz.io
# 如果前面还有 Cloudflare Worker / 网关，可按需填写；否则留空
WORKER_URL=https://api.ldspro.qzz.io
# 是否暂停新用户注册（已有用户仍可登录）
REGISTRATION_PAUSED=false

# LinuxDo OAuth
OAUTH_CLIENT_ID=your_linuxdo_client_id
OAUTH_CLIENT_SECRET=your_linuxdo_client_secret

# IDCFlare OAuth
IDCFLARE_CLIENT_ID=your_idcflare_client_id
IDCFLARE_CLIENT_SECRET=your_idcflare_client_secret

# Super Admin (initial setup)
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=changeme

# OpenAI / LLM
OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Fallback LLM (e.g., SiliconFlow / Qwen)
FALLBACK_PROVIDER=siliconflow
FALLBACK_API_KEY=sk-placeholder
FALLBACK_MODEL=Qwen/Qwen2.5-72B-Instruct
FALLBACK_BASE_URL=https://api.siliconflow.cn/v1

# Fallback chain (comma-separated provider names)
FALLBACK_CHAIN=openai,siliconflow

# Embedding
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# RAG
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.75
VECTOR_STORE_TYPE=chroma

# Rate Limits
LLM_RATE_LIMIT_PER_MINUTE=60
LLM_DAILY_TOKEN_BUDGET=1000000
LLM_MAX_COST_PER_DAY=50.00

# Log
LOG_LEVEL=debug
STRUCTURED_LOG=false

# ========================================
# Internal Service Authentication
# ========================================
# Used for internal API authentication between services
ADMIN_SECRET=your-admin-secret-key

# Alternative internal tokens (any one works)
# STORE_INTERNAL_TOKEN=your-store-internal-token
# GATEWAY_INTERNAL_TOKEN=your-gateway-internal-token
# TG_BOT_INTERNAL_KEY=your-tg-bot-internal-key
# TG_BOT_INTERNAL_TOKEN=your-tg-bot-internal-token
# IMAGE_AI_INTERNAL_KEY=your-image-ai-internal-key
# BACKEND_IMAGE_INTERNAL_KEY=your-backend-image-internal-key
# BACKEND_FIREWALL_SECRET=your-backend-firewall-secret

# ========================================
# Encryption Key
# ========================================
# Used to decrypt encrypted API keys stored in database (ENC: prefix)
ENCRYPTION_KEY=your-encryption-key

# ========================================
# Telegram Bot
# ========================================
TG_BOT_WEBHOOK_SECRET=your-telegram-webhook-secret
# TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret

# ========================================
# Site Configuration
# ========================================
# Comma-separated list of supported sites
SUPPORTED_SITES=linux.do,idcflare.com

# API version identifier
API_VERSION=v1

# ========================================
# Shop Maintenance Mode (optional)
# ========================================
# Options: normal, ldc_restricted, full
# SHOP_MAINTENANCE_MODE=normal
# SHOP_MAINTENANCE_TITLE=
# SHOP_MAINTENANCE_MESSAGE=
# SHOP_MAINTENANCE_REASON=
# SHOP_MAINTENANCE_ETA=
# SHOP_MAINTENANCE_STATUS_URL=

# ========================================
# Scheduler Switches (optional)
# ========================================
# ENABLE_BUFFER_WRITE_BACK=false
# ENABLE_LEADERBOARD_PRECOMPUTE=false
# ENABLE_SECURITY_CLEANUP_JOB=true
# BUY_AGENT_SHADOW_SNAPSHOT_AUTO_ENABLED=false
